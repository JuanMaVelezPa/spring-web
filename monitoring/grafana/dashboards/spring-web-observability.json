{
  "id": null,
  "uid": "spring-web-observability",
  "title": "Spring Web Observability",
  "tags": ["spring-web", "micrometer", "kafka", "outbox"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Auth Logins (rate/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(app_auth_login_total[5m])) by (outcome)", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Branch Commands (rate/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(app_branch_command_total[5m])) by (operation, outcome)", "legendFormat": "{{operation}}/{{outcome}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Use Case Duration p95 (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "1000 * histogram_quantile(0.95, sum(rate(app_use_case_duration_seconds_bucket[5m])) by (le, use_case))", "legendFormat": "{{use_case}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Outbox Publish (rate/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(app_outbox_publish_total[5m])) by (outcome)", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Notification Consumer (rate/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(app_notification_consumer_total[5m])) by (outcome)", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Outbox Lag (seconds)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "outbox_lag", "legendFormat": "outbox_lag" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Failed Notifications (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "failed_notifications", "legendFormat": "failed_notifications" }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
