# Use this file as a base for production-like runs.
# Do not commit real production secrets.
# Rotate all values before each real deployment.

ALERTMANAGER_CONFIG_FILE=./monitoring/alertmanager/alertmanager.yml
DISCORD_WEBHOOK_FILE=./monitoring/alertmanager/discord-webhook-url

# App security
APP_USER=admin
APP_PASSWORD=ChangeMe_StrongPassword_Prod
JWT_SECRET=ChangeMe_VeryLongRandomJwtSecret_AtLeast_32_Chars
JWT_EXPIRATION_SECONDS=3600
APP_SECURITY_ACTUATOR_PUBLIC=false

# Database
POSTGRES_DB=companydb
POSTGRES_USER=company
POSTGRES_PASSWORD=ChangeMe_DbPassword_Prod
DB_URL=jdbc:postgresql://postgres:5432/companydb
DB_USERNAME=company
DB_PASSWORD=ChangeMe_DbPassword_Prod

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=ChangeMe_GrafanaPassword_Prod
