          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "branches"
          ]
        }
      }
    },
    {
      "name": "5. Branches - Update",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"HQ Updated\",\n  \"city\": \"Bogota\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/branches/{{branchId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "branches",
            "{{branchId}}"
          ]
        }
      }
    },
    {
      "name": "6. Branches - Deactivate",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/branches/{{branchId}}/deactivate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "branches",
            "{{branchId}}",
            "deactivate"
          ]
        }
      }
    },
